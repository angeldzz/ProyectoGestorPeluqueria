<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestor Peluquería</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyectoGestorPeluqueria.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        List<Peluqueria> peluqueriasUsuario = Context.Session.GetObject<List<Peluqueria>>("peluqueriasUsuario");
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-scissors me-2 text-primary"></i>LookUp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i> Inicio
                            </a>
                        </li>
                        @if (User.Identity!.IsAuthenticated)
                        {
                            if (User.IsInRole("3"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Gestion" asp-action="CitasUsuario">
                                        <i class="fa-solid fa-calendar-check me-1"></i> Mis Citas
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("2"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-solid fa-store me-1"></i> Mis Negocios
                                        @if (peluqueriasUsuario != null)
                                        {
                                            <span class="badge bg-primary nav-negocios-badge">@peluqueriasUsuario.Count</span>
                                        }
                                    </a>
                                    <ul class="dropdown-menu">
                                        @if (peluqueriasUsuario != null && peluqueriasUsuario.Count > 0)
                                        {
                                            foreach (Peluqueria peluqueria in peluqueriasUsuario)
                                            {
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="Calendario"
                                                       asp-action="Gestionar"
                                                       asp-route-id="@peluqueria.PeluqueriaId">
                                                        <i class="fa-solid fa-scissors me-2 text-primary"></i>@peluqueria.Nombre
                                                    </a>
                                                </li>
                                            }
                                            <li><hr class="dropdown-divider" /></li>
                                        }
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="RegistrarNegocio">
                                                <i class="fa-solid fa-plus-circle me-2 text-success"></i> Registrar Negocio
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item me-2">
                                <span class="nav-link text-dark fw-semibold">
                                    <i class="fas fa-user-circle me-1 text-primary"></i>@User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-login" asp-area="" asp-controller="Managed" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-1"></i> Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Login" asp-action="Registrarse">Registrarse</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-login" asp-area="" asp-controller="Managed" asp-action="Login">
                                    <i class="fas fa-user-circle me-1"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container layout-main">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top">
        <div class="container app-footer">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-lg-6">
                    <div class="app-footer-brand">
                        <i class="fas fa-scissors me-2 text-primary"></i>LookUp
                    </div>
                    <p class="app-footer-text">
                        Gestión simple de citas, servicios y horarios para peluquerías.
                    </p>
                </div>

                <div class="col-6 col-lg-3">
                    <div class="app-footer-title">Navegación</div>
                    <div class="app-footer-links">
                        <a asp-controller="Home" asp-action="Index" class="app-footer-link">
                            <i class="fas fa-home"></i>Inicio
                        </a>
                        <a asp-controller="Home" asp-action="Privacy" class="app-footer-link">
                            <i class="fas fa-shield-alt"></i>Privacidad
                        </a>
                    </div>
                </div>

                <div class="col-6 col-lg-3">
                    <div class="app-footer-title">Cuenta</div>
                    <div class="app-footer-links">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <span class="app-footer-link">
                                <i class="fas fa-user-circle"></i>@User.Identity.Name
                            </span>
                            <a asp-controller="Managed" asp-action="Logout" class="app-footer-link">
                                <i class="fas fa-sign-out-alt"></i>Cerrar sesión
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Managed" asp-action="Login" class="app-footer-link">
                                <i class="fas fa-sign-in-alt"></i>Iniciar sesión
                            </a>
                            <a asp-controller="Login" asp-action="Registrarse" class="app-footer-link">
                                <i class="fas fa-user-plus"></i>Registrarse
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="app-footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-1">
                <span>&copy; @DateTime.Now.Year LookUp</span>
                <span>Todos los derechos reservados.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @{
        var swalSuccess = TempData["SwalSuccess"] as string;
        var swalError   = TempData["SwalError"]   as string;
    }
    @if (swalSuccess != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'Hecho', text: @Json.Serialize(swalSuccess), toast: true, position: 'top-end', showConfirmButton: false, timer: 3500, timerProgressBar: true });
        </script>
    }
    @if (swalError != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: @Json.Serialize(swalError), toast: true, position: 'top-end', showConfirmButton: false, timer: 4000, timerProgressBar: true });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>