<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestor Peluquería</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyectoGestorPeluqueria.styles.css" asp-append-version="true" />

    <style>
        /* Ajustes de estilo para un look más profesional */
        .navbar {
            transition: all 0.3s ease;
            backdrop-filter: blur(10px); /* Efecto cristal moderno */
            background-color: rgba(255, 255, 255, 0.95) !important;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #2c3e50 !important;
        }
        .nav-link {
            font-weight: 500;
            margin: 0 5px;
            transition: color 0.2s;
        }
        .nav-link:hover {
            color: #0d6efd !important; /* Color primario al pasar el mouse */
        }
        .btn-login {
            border-radius: 20px;
            padding: 8px 20px;
            font-weight: 600;
        }
        .footer {
            background-color: #f8f9fa;
        }
        /* --- Dropdown desktop --- */
        .dropdown-menu {
            border: none;
            box-shadow: 0 8px 24px rgba(0,0,0,0.10);
            border-radius: 12px;
            padding: 6px 0;
            min-width: 220px;
        }
        .dropdown-item {
            display: flex;
            align-items: center;
            font-weight: 500;
            padding: 9px 16px;
            border-radius: 8px;
            margin: 2px 6px;
            width: calc(100% - 12px);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: background 0.2s, color 0.2s;
        }
        .dropdown-item i {
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }
        .dropdown-item:hover {
            background-color: #e9f0ff;
            color: #0d6efd;
        }
        .dropdown-divider {
            margin: 4px 12px;
        }
        .nav-negocios-badge {
            font-size: 0.7rem;
            vertical-align: middle;
            margin-left: 4px;
        }
        /* --- Responsive: menú colapsado en móvil --- */
        @@media (max-width: 991.98px) {
            .navbar-nav + .navbar-nav {
                border-top: 1px solid #dee2e6;
                padding-top: 0.5rem;
                margin-top: 0.5rem;
            }
            .dropdown-menu {
                box-shadow: none;
                border-radius: 8px;
                background-color: #f8f9fa;
                min-width: 100%;
                margin-top: 2px !important;
            }
            .dropdown-item {
                margin: 1px 4px;
                width: calc(100% - 8px);
                padding-left: 1.25rem;
            }
            .btn-login {
                width: 100%;
                text-align: center;
                margin: 4px 0;
            }
        }
    </style>
</head>
<body>
    @{
        Usuario usuarioSession = Context.Session.GetObject<Usuario>("usuario");
        List<Peluqueria> peluqueriasUsuario = Context.Session.GetObject<List<Peluqueria>>("peluqueriasUsuario");
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-scissors me-2 text-primary"></i>GestorPeluquería
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i> Inicio
                            </a>
                        </li>
                        @if (usuarioSession != null)
                        {
                            @if (usuarioSession.RolId == 3)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Gestion" asp-action="CitasCliente">
                                        <i class="fa-solid fa-calendar-check me-1"></i> Mis Citas
                                    </a>
                                </li>
                            }
                            else if (usuarioSession.RolId == 2)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-solid fa-store me-1"></i> Mis Negocios
                                        @if (peluqueriasUsuario != null)
                                        {
                                            <span class="badge bg-primary nav-negocios-badge">@peluqueriasUsuario.Count</span>
                                        }
                                    </a>
                                    <ul class="dropdown-menu">
                                        @if (peluqueriasUsuario != null && peluqueriasUsuario.Count > 0)
                                        {
                                            @foreach (Peluqueria peluqueria in peluqueriasUsuario)
                                            {
                                                <li>
                                                    <a class="dropdown-item" asp-area="" asp-controller="Calendario"
                                                       asp-action="Gestionar"
                                                       asp-route-id="@peluqueria.PeluqueriaId">
                                                        <i class="fa-solid fa-scissors me-2 text-primary"></i>@peluqueria.Nombre
                                                    </a>
                                                </li>
                                            }
                                            <li><hr class="dropdown-divider" /></li>
                                        }
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="RegistrarNegocio">
                                                <i class="fa-solid fa-plus-circle me-2 text-success"></i> Registrar Negocio
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        
                        @if (usuarioSession != null)
                        {
                            <li class="nav-item me-2">
                                <span class="nav-link text-dark fw-semibold">
                                    <i class="fas fa-user-circle me-1 text-primary"></i>@usuarioSession.Nombre
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-login" asp-area="" asp-controller="Login" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-1"></i> Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Login" asp-action="Registrarse">Registrarse</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-login" asp-area="" asp-controller="Login" asp-action="Login">
                                    <i class="fas fa-user-circle me-1"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold">Gestor Peluquería</span> -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>