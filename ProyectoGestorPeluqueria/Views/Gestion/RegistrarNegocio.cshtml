@{
    ViewData["Title"] = "Registrar mi Negocio";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    #map {
        height: 350px;
        width: 100%;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        margin-bottom: 15px;
    }

    .business-container {
        min-height: 90vh;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        padding: 60px 0;
    }

    .form-card {
        background: white;
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .preview-container {
        width: 120px;
        height: 120px;
        border: 2px dashed #cbd5e1;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: #f8fafc;
        margin: 0 auto 20px;
    }

    #logoPreview {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

    .form-label {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 1.5px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

    .step-indicator {
        font-size: 0.75rem;
        font-weight: 800;
        color: #4f46e5;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .btn-save {
        background-color: #4f46e5;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s;
    }

        .btn-save:hover {
            background-color: #4338ca;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
        }

</style>

<div class="business-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="card form-card">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-5">
                            <span class="step-indicator">Paso 2: Configuración del Salón</span>
                            <h2 class="fw-bold mt-2">Registra tu Peluquería</h2>
                            <p class="text-muted">Cuéntanos más sobre tu local para que los clientes puedan encontrarte.</p>
                        </div>

                        <form asp-controller="Gestion" asp-action="RegistrarNegocio" method="post">
                            <!-- Sección del Logo -->
                            <div class="text-center mb-4">
                                <label class="form-label d-block">Imagen o Logo del Negocio</label>
                                <div class="preview-container">
                                    <i class="fas fa-image fa-2x text-slate-300" id="placeholderIcon"></i>
                                    <img id="logoPreview" src="#" alt="Vista previa">
                                </div>
                                <div class="col-md-10 mx-auto">
                                    <input type="url" name="UrlLogo" id="urlInput" class="form-control text-center"
                                           placeholder="Pega la URL de la imagen aquí (https://...)" required>
                                    <div class="form-text small mt-2">Copia el enlace de una imagen de internet o de tu servidor de imágenes.</div>
                                </div>
                            </div>

                            <hr class="my-5 opacity-10">

                            <!-- Datos Básicos -->
                            <div class="row g-4">
                                <div class="col-12">
                                    <label class="form-label">Nombre del Salón</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                                            <i class="fas fa-store text-muted"></i>
                                        </span>
                                        <input type="text" name="Nombre" class="form-control border-start-0"
                                               placeholder="Ej. Barbería El Corte de Oro" required style="border-radius: 0 12px 12px 0;">
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Ubicación del Salón</label>
                                    <div id="map"></div>
                                    <div class="form-text small mb-3">Haz clic en el mapa para situar tu peluquería exactamente.</div>
                                </div>

                                <div class="col-12 ">
                                    <label class="form-label">Dirección Física</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                                            <i class="fas fa-map-marker-alt text-muted"></i>
                                        </span>
                                        <input type="text" name="Direccion" id="direccionInput" class="form-control border-start-0"
                                               placeholder="Calle, Número, Ciudad" required style="border-radius: 0 12px 12px 0;">
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Coordenadas</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                                            <i class="fas fa-location-crosshairs text-muted"></i>
                                        </span>
                                        <input type="text" name="Cordenadas" id="coordenadasInput" class="form-control border-start-0"
                                               placeholder="Ej. 40.4167, -3.7037" readonly style="border-radius: 0 12px 12px 0;">
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Descripción del Negocio</label>
                                    <textarea name="Descripcion" class="form-control" rows="4"
                                              placeholder="Describe los servicios, el ambiente y por qué los clientes deberían elegirte..."></textarea>
                                </div>
                            </div>

                            <div class="mt-5">
                                <button type="submit" class="btn btn-primary btn-save w-100 text-white shadow">
                                    Finalizar Registro y Abrir Salón
                                </button>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-link w-100 text-muted mt-3 text-decoration-none small">
                                    Cancelar y volver al inicio
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>


</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        $(document).ready(function () {
            // --- Mapa Leaflet ---
            var defaultLat = 40.4167;
            var defaultLng = -3.7037;

            var map = L.map('map').setView([defaultLat, defaultLng], 13);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            var marker;

            function obtenerDireccion(lat, lng) {
                fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.display_name) {
                            $('#direccionInput').val(data.display_name);
                        }
                    })
                    .catch(err => console.error("Error en geocodificación:", err));
            }

            map.on('click', function (e) {
                var lat = e.latlng.lat;
                var lng = e.latlng.lng;

                $('#coordenadasInput').val(`${lat.toFixed(6)}, ${lng.toFixed(6)}`);

                if (marker) {
                    marker.setLatLng(e.latlng);
                } else {
                    marker = L.marker(e.latlng).addTo(map);
                }

                obtenerDireccion(lat, lng);
            });

            // --- Logo preview ---
            $('#urlInput').on('input', function () {
                var url = $(this).val();
                if (url && url.length > 5) {
                    $('#logoPreview').attr('src', url).show();
                    $('#placeholderIcon').hide();
                } else {
                    $('#logoPreview').hide();
                    $('#placeholderIcon').show();
                }
            });

            $('#logoPreview').on('error', function () {
                $(this).hide();
                $('#placeholderIcon').show();
            });
        });
    </script>
}