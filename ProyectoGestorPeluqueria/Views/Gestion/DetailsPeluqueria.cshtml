@model VwPeluqueriaDuenoServicio

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
@{
    ViewData["Title"] = Model.NombrePeluqueria;
    int usuarioId = User.Identity!.IsAuthenticated
        ? int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value)
        : 0;
    var empleados = ViewBag.Empleados as List<Empleado> ?? new List<Empleado>();
    var servicios = ViewBag.Servicios as List<Servicio> ?? new List<Servicio>();
}

<style>
    .detail-hero {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .salon-cover {
        height: 280px;
        object-fit: cover;
        width: 100%;
    }

    .info-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    }

    .section-title {
        font-size: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: #4f46e5;
        margin-bottom: 1rem;
    }

    .empleado-badge {
        border-radius: 12px;
        padding: 10px 16px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .service-pill {
        background: #eef2ff;
        color: #4f46e5;
        border-radius: 50px;
        padding: 4px 14px;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .detail-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #94a3b8;
        margin-bottom: 2px;
    }

    .detail-value {
        font-size: 0.95rem;
        color: #1e293b;
        font-weight: 500;
    }

    .coords-text {
        font-size: 0.82rem;
        font-family: 'Courier New', Courier, monospace;
        color: #64748b;
    }

    .btn-reservar {
        background-color: #4f46e5;
        border: none;
        padding: 14px 32px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s;
    }

    .btn-reservar:hover {
        background-color: #4338ca;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
    }

    .chat-card {
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        background: #ffffff;
        display: flex;
        flex-direction: column;
        min-height: 400px;
        border: 1px solid #e2e8f0;
    }

    .chat-header {
        background: linear-gradient(135deg,#4f46e5,#7c3aed);
    }

    .chat-body {
        flex: 1;
        overflow-y: auto;
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        padding: 16px;
    }

    .chat-input-wrap {
        background: #fff;
        border-top: 1px solid #e2e8f0;
        padding: 10px;
    }

    .chat-input {
        border-radius: 999px;
        border: 1px solid #cbd5e1;
    }

    .chat-input:focus {
        box-shadow: 0 0 0 .2rem rgba(79, 70, 229, .12);
        border-color: #6366f1;
    }

    .chat-send {
        border-radius: 999px;
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .msg-row {
        display: flex;
        margin-bottom: .35rem;
    }

    .msg-row.mine {
        justify-content: flex-end;
    }

    .msg-content {
        max-width: 78%;
    }

    .msg-bubble {
        display: inline-block;
        border-radius: 12px;
        padding: .4rem .65rem;
        font-size: .875rem;
        line-height: 1.25;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .msg-bubble.mine {
        background: #2563eb;
        color: #fff;
        box-shadow: 0 6px 16px rgba(37, 99, 235, .28);
    }

    .msg-bubble.other {
        background: #fff;
        color: #0f172a;
        border: 1px solid #e2e8f0;
        box-shadow: 0 3px 10px rgba(2, 6, 23, .06);
    }

    .msg-meta {
        font-size: .68rem;
        color: #64748b;
        margin-top: 2px;
    }

    .msg-actions {
        margin-top: 2px;
    }

    .msg-delete {
        border: 0;
        background: transparent;
        color: #dc2626;
        font-size: .7rem;
        padding: 0;
    }
</style>

<div class="container py-4">

    <!-- Breadcrumb + Acción -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <i class="fas fa-home me-1"></i>Inicio
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">@Model.NombrePeluqueria</li>
            </ol>
        </nav>
        @if (User.IsInRole("3"))
        {
            <a asp-controller="Calendario" asp-action="Reservar" asp-route-id="@Model.PeluqueriaId"
               class="btn btn-reservar text-white text-decoration-none px-4">
                <i class="fas fa-calendar-check me-2"></i>Reservar Cita
            </a>
        }
        else if ((User.IsInRole("2") || User.IsInRole("1")) && Model.DuenoId == usuarioId)
        {
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Calendario" asp-action="Gestionar" asp-route-id="@Model.PeluqueriaId"
                   class="btn btn-reservar text-white text-decoration-none px-4">
                    <i class="fas fa-calendar-alt me-2"></i>Gestionar Agenda
                </a>
                <a id="btnEliminarPeluqueria"
                   asp-controller="Gestion" asp-action="DetailsPeluqueria"
                   asp-route-id="@Model.PeluqueriaId" asp-route-delete="true"
                   class="btn text-white text-decoration-none px-4"
                   style="background-color:#dc2626;border:none;padding:14px 32px;border-radius:14px;font-weight:700;font-size:1rem;transition:all 0.3s;">
                    <i class="fas fa-trash me-2"></i>Eliminar peluquería
                </a>
            </div>
        }
        else if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Managed" asp-action="Login"
               class="btn btn-reservar text-white text-decoration-none px-4">
                <i class="fas fa-sign-in-alt me-2"></i>Inicia sesión para reservar
            </a>
        }
    </div>

    <div class="row g-4">

        <!-- Columna principal -->
        <div class="col-lg-8">

            <!-- Hero de la peluquería -->
            <div class="detail-hero">
                <div class="position-relative">
                    <img src="@(Model.UrlLogo ?? Url.Content("~/images/peluqueria-estandar.webp"))"
                         class="salon-cover"
                         alt="@Model.NombrePeluqueria"
                         onerror="this.onerror=null;this.src='@Url.Content("~/images/peluqueria-estandar.webp")';this.alt='';">
                    @if (servicios.Any())
                    {
                        <span class="position-absolute top-0 end-0 m-3 service-pill shadow-sm">
                            <i class="fas fa-tag me-1"></i>@servicios.Count servicio(s)
                        </span>
                    }
                </div>
                <div class="p-4">
                    <h1 class="fw-bold mb-1" style="font-size:2rem;">@Model.NombrePeluqueria</h1>
                    <p class="text-muted mb-0">
                        <i class="fas fa-user me-1"></i>Propietario: <strong>@Model.NombreDueno</strong>
                    </p>
                </div>
            </div>

            <!-- Ubicación + Chat en fila -->
            @{
                string mapaClass = "col-12 col-md-6";
                string chatClass = "col-12 col-md-6";
                
                // Si no hay servicios ni empleados, mantenemos en una fila (mitad/mitad como estaba por defecto al entrar el col-lg-8 en la grid de arriba)
                // Si hay servicios/empleados el col-lg-8 está ocupando menos espacio, pero queremos mapa y chat 1 a 1 en ese espacio
                if (servicios.Any() || empleados.Any())
                {
                    mapaClass = "col-12";
                    chatClass = "col-12 mt-4";
                }
            }
            <div class="row g-3 mb-4">

                <!-- Mapa -->
                <div class="@mapaClass">
                    <div class="card info-card p-4 h-100">
                        <p class="section-title"><i class="fas fa-map-marker-alt me-2"></i>Ubicación</p>
                        @if (!string.IsNullOrEmpty(Model.Direccion))
                        {
                            <div class="mb-3">
                                <div class="detail-label">Dirección</div>
                                <div class="detail-value">@Model.Direccion</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Coordenadas))
                        {
                            <div id="detailMap" style="height:260px; border-radius:12px; overflow:hidden;"></div>
                        }
                        else if (string.IsNullOrEmpty(Model.Direccion))
                        {
                            <p class="text-muted small mb-0">
                                <i class="fas fa-info-circle me-1"></i>Ubicación no especificada.
                            </p>
                        }
                    </div>
                </div>

                <!-- Chat -->
                <div class="@chatClass">
                    <div class="chat-card">
                        <div class="chat-header d-flex align-items-center gap-2 px-4 py-3" style="flex-shrink:0;">
                            <i class="fas fa-comments text-white"></i>
                            <span class="fw-semibold text-white">Chat con @Model.NombrePeluqueria</span>
                        </div>
                        <div class="chat-body" id="chatMessages"></div>
                        <div class="chat-input-wrap d-flex gap-2" style="flex-shrink:0;">
                            <input type="text" id="mensajeInput" class="form-control form-control-sm chat-input"
                                   placeholder="@(User.Identity!.IsAuthenticated ? "Escribe un mensaje..." : "Inicia sesión para enviar mensajes")"
                                   @(User.Identity!.IsAuthenticated ? "" : "disabled") />
                            <button id="enviarMensajeBtn" class="btn btn-primary btn-sm chat-send" @(User.Identity!.IsAuthenticated ? "" : "disabled")>
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Columna lateral -->
        <div class="col-lg-4">

            <!-- Servicios -->
            @if (servicios.Any())
            {
                <div class="card info-card p-4 mb-4">
                    <p class="section-title"><i class="fas fa-concierge-bell me-2"></i>Servicios</p>
                    <div class="d-flex flex-column gap-3">
                        @foreach (var servicio in servicios)
                        {
                            <div class="empleado-badge justify-content-between">
                                <div>
                                    <div class="fw-semibold">@servicio.Nombre</div>
                                    <span class="text-muted" style="font-size:0.82rem;">
                                        <i class="fas fa-clock me-1"></i>@servicio.DuracionMin min
                                    </span>
                                </div>
                                <span class="fw-bold text-primary">@servicio.Precio.ToString("C")</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Equipo -->
            <div class="card info-card p-4 mb-4">
                <p class="section-title"><i class="fas fa-users me-2"></i>Equipo</p>
                @if (empleados.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var emp in empleados)
                        {
                            <div class="empleado-badge">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:36px;height:36px;background:#eef2ff;">
                                    <i class="fas fa-cut text-primary" style="font-size:0.8rem;"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <div class="fw-semibold text-truncate small">@emp.Nombre</div>
                                    @if (emp.Activo.HasValue)
                                    {
                                        <span class="badge @(emp.Activo.Value ? "bg-success" : "bg-secondary") rounded-pill" style="font-size:0.65rem;">
                                            @(emp.Activo.Value ? "Disponible" : "No disponible")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">
                        <i class="fas fa-info-circle me-1"></i>Sin empleados registrados.
                    </p>
                }
            </div>

            <!-- Contacto del propietario -->
            <div class="card info-card p-4 mb-4">
                <p class="section-title"><i class="fas fa-address-card me-2"></i>Contacto</p>
                <div class="mb-3">
                    <div class="detail-label">Propietario</div>
                    <div class="detail-value">@Model.NombreDueno</div>
                </div>
                <div class="mb-3">
                    <div class="detail-label">Email</div>
                    <div class="detail-value">
                        <a href="mailto:@Model.EmailDueno" class="text-decoration-none">@Model.EmailDueno</a>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.TelefonoDueno))
                {
                    <div>
                        <div class="detail-label">Teléfono</div>
                        <div class="detail-value">
                            <a href="tel:@Model.TelefonoDueno" class="text-decoration-none">@Model.TelefonoDueno</a>
                        </div>
                    </div>
                }
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @if (!string.IsNullOrEmpty(Model.Coordenadas))
    {
        <script>
            (function () {
                var parts = '@Model.Coordenadas'.split(',');
                var lat = parseFloat(parts[0]);
                var lng = parseFloat(parts[1]);
                if (!isNaN(lat) && !isNaN(lng)) {
                    var map = L.map('detailMap', { scrollWheelZoom: false, dragging: false, zoomControl: true })
                               .setView([lat, lng], 15);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap contributors'
                    }).addTo(map);
                    L.marker([lat, lng]).addTo(map)
                     .bindPopup('<strong>@Html.Raw(Model.NombrePeluqueria)</strong><br>@Html.Raw(Model.Direccion ?? "")')
                     .openPopup();
                }
            })();
        </script>
    }
    <script>
        document.getElementById('btnEliminarPeluqueria')?.addEventListener('click', function (e) {
            e.preventDefault();
            const url = this.href;
            Swal.fire({
                title: '¿Eliminar peluquería?',
                html: 'Vas a eliminar <strong>@Html.Raw(Model.NombrePeluqueria)</strong>.<br>Esta acción <u>no se puede deshacer</u>.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="fas fa-trash me-1"></i> Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) window.location.href = url;
            });
        });
    </script>

    @if (User.Identity!.IsAuthenticated)
    {
        <script>
            const peluqueriaId = @Model.PeluqueriaId;
            const currentUserId = @usuarioId;
            const chatMessages = document.getElementById('chatMessages');
            const mensajeInput = document.getElementById('mensajeInput');
            const enviarMensajeBtn = document.getElementById('enviarMensajeBtn');

            function scrollBottom() {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            function escapeHtml(text) {
                return (text ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function appendMessage(m) {
                const esMio = m.emisorId === currentUserId;
                const rowClass = esMio ? 'msg-row mine' : 'msg-row';
                const bubbleClass = esMio ? 'msg-bubble mine' : 'msg-bubble other';
                const hora = m.hora ? escapeHtml(m.hora) : '';
                const iconOrMargin = esMio
                    ? ""
                    : `<div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0 me-2" style="width:30px;height:30px;"><i class="fas fa-store text-white" style="font-size:0.62rem;"></i></div>`;

                const deleteBtn = esMio
                    ? `<div class="msg-actions"><button class="msg-delete btn-delete-msg" data-id="${m.mensajeId}">Eliminar</button></div>`
                    : '';

                const html = `
                    <div class="${rowClass}">
                        ${iconOrMargin}
                        <div class="msg-content">
                            <div class="${bubbleClass}">${escapeHtml(m.mensaje)}</div>
                            <div class="msg-meta">${hora}</div>
                            ${deleteBtn}
                        </div>
                    </div>
                `;

                chatMessages.insertAdjacentHTML('beforeend', html);
            }

            async function loadMessages() {
                try {
                    const res = await fetch(`/Gestion/GetMensajes?peluqueriaId=${peluqueriaId}`);
                    if (!res.ok) return;

                    const mensajes = await res.json();
                    chatMessages.innerHTML = '';

                    if (mensajes.length === 0) {
                        chatMessages.innerHTML = `
                            <div class="msg-row">
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0 me-2" style="width:30px;height:30px;">
                                    <i class="fas fa-store text-white" style="font-size:0.62rem;"></i>
                                </div>
                                <div class="msg-content">
                                    <div class="msg-bubble other">¡Hola! ¿En qué podemos ayudarte? 😊</div>
                                </div>
                            </div>
                        `;
                    } else {
                        mensajes.forEach(appendMessage);
                    }

                    scrollBottom();
                } catch (e) {
                    console.error("Error loading messages:", e);
                }
            }

            enviarMensajeBtn.addEventListener('click', async () => {
                const text = mensajeInput.value.trim();
                if (!text) return;

                try {
                    const res = await fetch('/Gestion/EnviarMensaje', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ peluqueriaId: peluqueriaId, mensajeText: text })
                    });

                    if (res.ok) {
                        mensajeInput.value = '';
                        await loadMessages();
                    }
                } catch (e) {
                    console.error("Error sending message:", e);
                }
            });

            chatMessages.addEventListener('click', async (e) => {
                const btn = e.target.closest('.btn-delete-msg');
                if (!btn) return;

                const mensajeId = parseInt(btn.dataset.id);
                if (isNaN(mensajeId)) return;

                try {
                    const res = await fetch('/Gestion/DeleteMensaje', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ mensajeId })
                    });

                    if (res.ok) {
                        await loadMessages();
                    }
                } catch (e) {
                    console.error("Error deleting message:", e);
                }
            });

            mensajeInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') enviarMensajeBtn.click();
            });

            loadMessages();
        </script>
    }
}
