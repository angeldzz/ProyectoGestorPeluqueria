@model VwPeluqueriaDuenoServicio

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />

@{
    ViewData["Title"] = "Reservar Cita - " + Model.NombrePeluqueria;
    var empleados = ViewBag.Empleados as List<Empleado> ?? new List<Empleado>();
    var servicios = ViewBag.Servicios as List<Servicio> ?? new List<Servicio>();
    var clienteId = ViewBag.ClienteId is int cId ? cId : 0;
}

<style>
    /* Evita el salto de maquetación cuando Bootstrap abre/cierra el modal */
    html {
        overflow-y: scroll;
    }

    #calendar {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.04);
    }

    .leyenda-dot {
        display: inline-block;
        width: 11px;
        height: 11px;
        border-radius: 50%;
        vertical-align: middle;
        margin-right: 4px;
        flex-shrink: 0;
    }

    .legend-pill {
        display: inline-flex;
        align-items: center;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 0.8rem;
        color: #475569;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        font-weight: 500;
    }

    .page-header-card {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 18px;
        padding: 26px 30px;
        color: white;
        box-shadow: 0 8px 28px rgba(79, 70, 229, 0.25);
    }

    .modal-content {
        border-radius: 20px !important;
        overflow: hidden;
        border: none !important;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18) !important;
    }

    .modal-header-gradient {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        padding: 20px 24px 18px;
        border: none;
    }

    .modal-header-gradient .modal-title {
        color: white;
    }

    .modal-header-gradient .btn-close {
        filter: brightness(0) invert(1);
        opacity: 0.75;
    }

    .modal-header-gradient .btn-close:hover {
        opacity: 1;
    }

    .modal-body .form-label {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .modal-body .form-control,
    .modal-body .form-select {
        border-radius: 10px;
        border-color: #e5e7eb;
        font-size: 0.9rem;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .modal-body .form-control:focus,
    .modal-body .form-select:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12);
    }

    .modal-body .form-control.bg-light {
        background-color: #f9fafb !important;
        color: #9ca3af;
    }

    .btn-reservar {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        padding: 8px 22px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.88rem;
        color: white;
        transition: opacity 0.2s, box-shadow 0.2s, transform 0.1s;
    }

    .btn-reservar:hover:not(:disabled) {
        opacity: 0.9;
        box-shadow: 0 4px 16px rgba(79, 70, 229, 0.35);
        transform: translateY(-1px);
        color: white;
    }

    .btn-reservar:active:not(:disabled) {
        transform: translateY(0);
    }

    .btn-reservar:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        color: white;
    }
</style>

<div class="py-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-home me-1"></i>Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Gestion" asp-action="DetailsPeluqueria" asp-route-id="@Model.PeluqueriaId" class="text-decoration-none">
                    @Model.NombrePeluqueria
                </a>
            </li>
            <li class="breadcrumb-item active">Reservar Cita</li>
        </ol>
    </nav>

    <div class="page-header-card mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h2 class="fw-bold mb-1 fs-4 text-white">
                    <i class="fas fa-calendar-plus me-2"></i>Reservar Cita
                </h2>
                <p class="mb-0" style="color:rgba(255,255,255,0.75); font-size:0.875rem;">
                    @Model.NombrePeluqueria &middot; Haz clic en un hueco disponible para reservar
                </p>
            </div>
            <div>
                <select id="filtroEmpleado" class="form-select form-select-sm"
                        style="min-width:190px; border-radius:10px;"
                        onchange="calendar && calendar.refetchEvents()">
                    <option value="">Todos los empleados</option>
                    @foreach (var emp in empleados)
                    {
                        <option value="@emp.EmpleadoId">@emp.Nombre</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="mb-3 d-flex flex-wrap gap-2">
        <span class="legend-pill"><span class="leyenda-dot" style="background:#86efac; border:1px solid #4ade80;"></span>Disponible</span>
        <span class="legend-pill"><span class="leyenda-dot" style="background:#4f46e5;"></span>Tu cita</span>
        <span class="legend-pill"><span class="leyenda-dot" style="background:#cbd5e1; border:1px solid #94a3b8;"></span>Ocupado</span>
    </div>

    <div id="calendar"></div>

</div>

<!-- Modal: Reservar Cita -->
<div class="modal fade" id="modalReservar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header-gradient">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-calendar-check me-2"></i>Nueva Reserva
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pt-3 pb-2">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Empleado</label>
                    <select class="form-select" id="resEmpleado">
                        <option value="" disabled selected>Selecciona fecha y servicio...</option>
                    </select>
                    <div id="resEmpleadoInfo" class="form-text text-warning small d-none">
                        <i class="fas fa-exclamation-triangle me-1"></i>No hay empleados disponibles en este horario.
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Servicio</label>
                    <select class="form-select" id="resServicio" onchange="actualizarFin(); cargarEmpleadosDisponibles();">
                        @foreach (var s in servicios)
                        {
                            <option value="@s.ServicioId" data-duracion="@s.DuracionMin">
                                @s.Nombre (@s.DuracionMin min) — @s.Precio.ToString("C")
                            </option>
                        }
                    </select>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Inicio</label>
                        <input type="datetime-local" class="form-control" id="resInicio" onchange="actualizarFin(); cargarEmpleadosDisponibles();" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Fin (estimado)</label>
                        <input type="datetime-local" class="form-control bg-light" id="resFin" readonly />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Notas (opcional)</label>
                    <textarea class="form-control" id="resNotas" rows="2" placeholder="Ej: preferencias, alergias..."></textarea>
                </div>
                <div id="resError" class="alert alert-danger py-2 small d-none"></div>
                <div id="resSuccess" class="alert alert-success py-2 small d-none">
                    <i class="fas fa-check-circle me-1"></i>¡Cita reservada con éxito!
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-2">
                <button type="button" class="btn btn-light btn-sm px-3" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-reservar btn-sm" id="btnConfirmar" onclick="confirmarReserva()">
                    <i class="fas fa-check me-1"></i>Confirmar Reserva
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/es.global.min.js"></script>
    <script>
        const peluqueriaId = @Model.PeluqueriaId;
        const clienteIdActual = @clienteId;
        let calendar;
        let empleadoPreseleccionado = null;

        document.addEventListener('DOMContentLoaded', function () {
            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                locale: 'es',
                firstDay: 1,
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: { today: 'Hoy', month: 'Mes', week: 'Semana', day: 'Día' },
                slotMinTime: '07:00:00',
                slotMaxTime: '22:00:00',
                slotDuration: '00:30:00',
                allDaySlot: false,
                nowIndicator: true,
                height: 'auto',
                dateClick: function (info) {
                    empleadoPreseleccionado = null;
                    abrirModalReservar(info.dateStr);
                },
                eventClick: function (info) {
                    const props = info.event.extendedProps;
                    if (props.type === 'horario') {
                        empleadoPreseleccionado = props.empleadoId;
                        abrirModalReservar(info.event.startStr);
                    }
                },
                events: function (info, successCallback, failureCallback) {
                    const emp = document.getElementById('filtroEmpleado').value;
                    const url = `/Calendario/GetEventos?peluqueriaId=${peluqueriaId}` +
                        `&start=${encodeURIComponent(info.startStr)}` +
                        `&end=${encodeURIComponent(info.endStr)}` +
                        (emp ? `&empleadoId=${emp}` : '');
                    fetch(url)
                        .then(r => {
                            if (!r.ok) throw new Error(`HTTP ${r.status}`);
                            return r.json();
                        })
                        .then(data => {
                            const processed = [];
                            data.forEach(ev => {
                                if (ev.extendedProps && ev.extendedProps.type === 'cita') {
                                    if (ev.extendedProps.clienteId === clienteIdActual) {
                                        ev.backgroundColor = '#4f46e5';
                                        ev.borderColor = '#4338ca';
                                        ev.title = `Tu cita · ${ev.extendedProps.servicio || ''}`;
                                    } else {
                                        ev.title = 'Ocupado';
                                        ev.backgroundColor = '#cbd5e1';
                                        ev.borderColor = '#94a3b8';
                                    }
                                    processed.push(ev);
                                } else if (ev.extendedProps && ev.extendedProps.type === 'horario') {
                                    processed.push(ev);
                                    processed.push({
                                        id: ev.id + '_label',
                                        title: `✓ ${ev.extendedProps.empleadoNombre}`,
                                        start: ev.start,
                                        end: ev.end,
                                        backgroundColor: '#86efac',
                                        borderColor: '#4ade80',
                                        textColor: '#166534',
                                        extendedProps: ev.extendedProps
                                    });
                                } else {
                                    processed.push(ev);
                                }
                            });
                            successCallback(processed);
                        })
                        .catch(err => failureCallback(err instanceof Error ? err : new Error(String(err))));
                }
            });
            calendar.render();
        });

        function abrirModalReservar(dateStr) {
            document.getElementById('resInicio').value = dateStr.substring(0, 16);
            document.getElementById('resError').classList.add('d-none');
            document.getElementById('resSuccess').classList.add('d-none');
            document.getElementById('btnConfirmar').disabled = false;
            actualizarFin();
            cargarEmpleadosDisponibles();
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalReservar')).show();
        }

        async function cargarEmpleadosDisponibles() {
            const inicio = document.getElementById('resInicio').value;
            const servicioId = document.getElementById('resServicio').value;
            const select = document.getElementById('resEmpleado');
            const infoEl = document.getElementById('resEmpleadoInfo');
            const btnConfirmar = document.getElementById('btnConfirmar');

            infoEl.classList.add('d-none');

            if (!inicio || !servicioId) {
                select.innerHTML = '<option value="" disabled selected>Selecciona fecha y servicio...</option>';
                btnConfirmar.disabled = true;
                return;
            }

            select.innerHTML = '<option value="" disabled selected>Cargando...</option>';

            try {
                const url = `/Calendario/GetEmpleadosDisponibles?peluqueriaId=${peluqueriaId}` +
                    `&inicio=${encodeURIComponent(inicio)}&servicioId=${servicioId}`;
                const resp = await fetch(url);
                if (!resp.ok) throw new Error();
                const empleados = await resp.json();

                select.innerHTML = '';
                if (empleados.length === 0) {
                    select.innerHTML = '<option value="" disabled selected>Sin disponibilidad</option>';
                    infoEl.classList.remove('d-none');
                    btnConfirmar.disabled = true;
                } else {
                    empleados.forEach(emp => {
                        const opt = document.createElement('option');
                        opt.value = emp.empleadoId;
                        opt.textContent = emp.nombre;
                        select.appendChild(opt);
                    });
                    if (empleadoPreseleccionado) {
                        const exists = empleados.some(e => e.empleadoId === empleadoPreseleccionado);
                        if (exists) select.value = empleadoPreseleccionado;
                    }
                    const empFiltro = document.getElementById('filtroEmpleado').value;
                    if (!empleadoPreseleccionado && empFiltro) {
                        const exists = empleados.some(e => e.empleadoId === parseInt(empFiltro));
                        if (exists) select.value = empFiltro;
                    }
                    btnConfirmar.disabled = false;
                }
            } catch {
                select.innerHTML = '<option value="" disabled selected>Error al cargar</option>';
                btnConfirmar.disabled = true;
            }
        }

        function actualizarFin() {
            const inicio = document.getElementById('resInicio').value;
            const select = document.getElementById('resServicio');
            const duracion = parseInt(select.options[select.selectedIndex]?.dataset?.duracion || '30');
            if (inicio) {
                const fin = new Date(new Date(inicio).getTime() + duracion * 60000);
                document.getElementById('resFin').value = fin.toISOString().substring(0, 16);
            }
        }

        async function confirmarReserva() {
            const empleadoId = parseInt(document.getElementById('resEmpleado').value);
            const servicioId = parseInt(document.getElementById('resServicio').value);
            const inicio = document.getElementById('resInicio').value;
            const notas = document.getElementById('resNotas').value;
            const errEl = document.getElementById('resError');
            errEl.classList.add('d-none');

            if (!inicio) {
                errEl.textContent = 'Selecciona una fecha y hora de inicio.';
                errEl.classList.remove('d-none');
                return;
            }

            if (!empleadoId) {
                errEl.textContent = 'Selecciona un empleado disponible.';
                errEl.classList.remove('d-none');
                return;
            }

            const btnConfirmar = document.getElementById('btnConfirmar');
            btnConfirmar.disabled = true;
            btnConfirmar.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Confirmando...';
            const resp = await fetch('/Calendario/CrearCita', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ empleadoId, servicioId, inicio, notas })
            });

            if (resp.ok) {
                btnConfirmar.innerHTML = '<i class="fas fa-check me-1"></i>¡Reservado!';
                document.getElementById('resSuccess').classList.remove('d-none');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(document.getElementById('modalReservar')).hide();
                    calendar.refetchEvents();
                }, 1500);
            } else {
                const data = await resp.json().catch(() => ({}));
                errEl.textContent = data.error || 'El empleado no está disponible en ese horario.';
                errEl.classList.remove('d-none');
                btnConfirmar.innerHTML = '<i class="fas fa-check me-1"></i>Confirmar Reserva';
                btnConfirmar.disabled = false;
            }
        }
    </script>
}
