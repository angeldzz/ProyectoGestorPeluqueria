@model VwPeluqueriaDuenoServicio

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />

@{
    ViewData["Title"] = "Gestionar Agenda - " + Model.NombrePeluqueria;
    var empleados = ViewBag.Empleados as List<Empleado> ?? new List<Empleado>();
    var servicios = ViewBag.Servicios as List<Servicio> ?? new List<Servicio>();
}

<style>
    #calendar {
        background: white;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    }

    .leyenda-dot {
        display: inline-block;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        vertical-align: middle;
        margin-right: 4px;
    }
</style>

<div class="py-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-home me-1"></i>Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Gestion" asp-action="DetailsPeluqueria" asp-route-id="@Model.PeluqueriaId" class="text-decoration-none">
                    @Model.NombrePeluqueria
                </a>
            </li>
            <li class="breadcrumb-item active">Gestionar Agenda</li>
        </ol>
    </nav>

    <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-3">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="fas fa-calendar-alt me-2 text-primary"></i>Gestión de Agenda
            </h2>
            <p class="text-muted small mb-0">@Model.NombrePeluqueria</p>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <select id="filtroEmpleado" class="form-select form-select-sm" style="min-width:180px;"
                    onchange="calendar && calendar.refetchEvents()">
                <option value="">Todos los empleados</option>
                @foreach (var emp in empleados)
                {
                    <option value="@emp.EmpleadoId">@emp.Nombre</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-success fw-semibold" onclick="abrirModalHorario(null, null)">
                <i class="fas fa-clock me-1"></i>Añadir Horario
            </button>
            <button class="btn btn-sm btn-outline-primary fw-semibold"
                    onclick="bootstrap.Modal.getOrCreateInstance(document.getElementById('modalGestionarServicios')).show()">
                <i class="fas fa-concierge-bell me-1"></i>Servicios
            </button>
            <button class="btn btn-sm btn-outline-secondary fw-semibold"
                    onclick="bootstrap.Modal.getOrCreateInstance(document.getElementById('modalGestionarEmpleados')).show()">
                <i class="fas fa-users-cog me-1"></i>Empleados
            </button>
        </div>
    </div>

    <div class="mb-3 d-flex flex-wrap gap-3 small text-secondary">
        <span><span class="leyenda-dot" style="background:#f59e0b;"></span>Pendiente</span>
        <span><span class="leyenda-dot" style="background:#10b981;"></span>Completada</span>
        <span><span class="leyenda-dot" style="background:#ef4444;"></span>Cancelada</span>
        <span><span class="leyenda-dot" style="background:#64748b;"></span>No presentado</span>
        <span><span class="leyenda-dot" style="background:#86efac; border:1px solid #4ade80;"></span>Horario disponible</span>
    </div>

    <div id="calendar"></div>

</div>

<!-- Modal: Detalles de Cita -->
<div class="modal fade" id="modalCita" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-calendar-check me-2 text-primary"></i>Detalles de la Cita
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="detCitaId" />
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Cliente</div>
                        <div id="detCliente" class="fw-semibold"></div>
                    </div>
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Empleado</div>
                        <div id="detEmpleado"></div>
                    </div>
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Servicio</div>
                        <div id="detServicio"></div>
                    </div>
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Estado</div>
                        <div id="detEstado"></div>
                    </div>
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Inicio</div>
                        <div id="detInicio"></div>
                    </div>
                    <div class="col-6">
                        <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Fin</div>
                        <div id="detFin"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="text-uppercase fw-bold text-muted mb-1" style="font-size:.72rem;letter-spacing:.8px;">Notas</div>
                    <div id="detNotas" class="text-muted fst-italic small"></div>
                </div>
                <hr class="my-2" />
                <label class="form-label fw-semibold small">Cambiar estado</label>
                <select class="form-select" id="nuevoEstado">
                    <option value="1">Pendiente</option>
                    <option value="2">Completada</option>
                    <option value="3">Cancelada</option>
                    <option value="4">No presentado</option>
                </select>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary btn-sm fw-semibold" onclick="guardarEstado()">
                    <i class="fas fa-save me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Añadir Horario -->
<div class="modal fade" id="modalHorario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-clock me-2 text-success"></i>Añadir Horario de Empleado
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Empleado</label>
                    <select class="form-select" id="horEmpleado">
                        @foreach (var emp in empleados)
                        {
                            <option value="@emp.EmpleadoId">@emp.Nombre</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Apertura</label>
                    <input type="datetime-local" class="form-control" id="horApertura" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Cierre</label>
                    <input type="datetime-local" class="form-control" id="horCierre" />
                </div>
                <div id="horError" class="alert alert-danger py-2 small d-none"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success btn-sm fw-semibold" onclick="guardarHorario()">
                    <i class="fas fa-check me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Añadir Servicio -->
<div class="modal fade" id="modalServicio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-concierge-bell me-2 text-primary"></i>Añadir Servicio
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Nombre</label>
                    <input type="text" class="form-control" id="srvNombre" placeholder="Ej. Corte de pelo" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Precio (€)</label>
                        <input type="number" class="form-control" id="srvPrecio" step="0.01" min="0.01" placeholder="15.00" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Duración (min)</label>
                        <input type="number" class="form-control" id="srvDuracion" min="1" placeholder="30" />
                    </div>
                </div>
                <div id="srvError" class="alert alert-danger py-2 small d-none"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary btn-sm fw-semibold" onclick="guardarServicio()">
                    <i class="fas fa-plus me-1"></i>Añadir
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Añadir Empleado -->
<div class="modal fade" id="modalEmpleado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-user-plus me-2 text-secondary"></i>Añadir Empleado
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Nombre</label>
                    <input type="text" class="form-control" id="empNombre" placeholder="Ej. Carlos García" />
                </div>
                <div id="empError" class="alert alert-danger py-2 small d-none"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm fw-semibold" onclick="guardarEmpleado()">
                    <i class="fas fa-user-plus me-1"></i>Añadir
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Gestionar Servicios -->
<div class="modal fade" id="modalGestionarServicios" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-concierge-bell me-2 text-primary"></i>Gestionar Servicios
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (servicios.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var srv in servicios)
                        {
                            <div class="d-flex align-items-center justify-content-between p-2 rounded-3 border">
                                <div>
                                    <div class="fw-semibold small">@srv.Nombre</div>
                                    <div class="text-muted" style="font-size:.78rem;">
                                        @srv.Precio.ToString("C") · @srv.DuracionMin min
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-id="@srv.ServicioId"
                                        data-nombre="@srv.Nombre"
                                        onclick="eliminarServicio(this)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">
                        <i class="fas fa-info-circle me-1"></i>No hay servicios registrados.
                    </p>
                }
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary btn-sm fw-semibold"
                        data-bs-dismiss="modal" onclick="abrirModalServicio()">
                    <i class="fas fa-plus me-1"></i>Añadir nuevo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Gestionar Empleados -->
<div class="modal fade" id="modalGestionarEmpleados" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-users me-2 text-secondary"></i>Gestionar Empleados
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (empleados.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var emp in empleados)
                        {
                            <div class="d-flex align-items-center justify-content-between p-2 rounded-3 border">
                                <div class="fw-semibold small">
                                    <i class="fas fa-cut me-2 text-primary" style="font-size:.75rem;"></i>@emp.Nombre
                                </div>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-id="@emp.EmpleadoId"
                                        data-nombre="@emp.Nombre"
                                        onclick="eliminarEmpleado(this)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">
                        <i class="fas fa-info-circle me-1"></i>No hay empleados registrados.
                    </p>
                }
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm fw-semibold"
                        data-bs-dismiss="modal" onclick="abrirModalEmpleado()">
                    <i class="fas fa-user-plus me-1"></i>Añadir nuevo
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/es.global.min.js"></script>
    <script>
        const peluqueriaId = @Model.PeluqueriaId;
        let calendar;
        let deletingHorario = false;

        document.addEventListener('DOMContentLoaded', function () {
            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                locale: 'es',
                firstDay: 1,
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: { today: 'Hoy', month: 'Mes', week: 'Semana', day: 'Día' },
                slotMinTime: '06:00:00',
                slotMaxTime: '24:00:00',
                slotDuration: '00:30:00',
                allDaySlot: false,
                selectable: true,
                selectMirror: true,
                selectAllow: function (selectInfo) {
                    return selectInfo.start >= new Date();
                },
                nowIndicator: true,
                height: 'auto',
                select: function (info) {
                    if (deletingHorario) { calendar.unselect(); return; }
                    abrirModalHorario(info.startStr, info.endStr);
                    calendar.unselect();
                },
                eventClick: function (info) {
                    if (info.event.extendedProps.type === 'cita') {
                        abrirModalCita(info.event);
                    } else if (info.event.extendedProps.type === 'horario') {
                        confirmarEliminarHorario(info.event);
                    }
                },
                eventDidMount: function (info) {
                    if (info.event.extendedProps.type === 'horario') {
                        const btn = document.createElement('button');
                        btn.title = 'Eliminar horario';
                        btn.style.cssText = 'position:absolute;top:2px;right:4px;font-size:.6rem;padding:1px 6px;z-index:5;border-radius:4px;background:#dc2626;color:white;border:none;cursor:pointer;line-height:1.4;';
                        btn.innerHTML = '<i class="fas fa-times"></i>';
                        btn.addEventListener('mousedown', function (e) {
                            e.stopPropagation();
                            e.preventDefault();
                            deletingHorario = true;
                            setTimeout(() => { deletingHorario = false; }, 500);
                        });
                        btn.addEventListener('click', function (e) {
                            e.stopPropagation();
                            e.preventDefault();
                            confirmarEliminarHorario(info.event);
                        });
                        info.el.appendChild(btn);
                    }
                },
                events: function (info, successCallback, failureCallback) {
                    const emp = document.getElementById('filtroEmpleado').value;
                    const url = `/Calendario/GetEventos?peluqueriaId=${peluqueriaId}` +
                        `&start=${encodeURIComponent(info.startStr)}` +
                        `&end=${encodeURIComponent(info.endStr)}` +
                        (emp ? `&empleadoId=${emp}` : '');
                    fetch(url)
                        .then(r => {
                            if (!r.ok) throw new Error(`HTTP ${r.status}`);
                            return r.json();
                        })
                        .then(data => successCallback(data))
                        .catch(err => failureCallback(err instanceof Error ? err : new Error(String(err))));
                }
            });
            calendar.render();
        });

        function abrirModalCita(event) {
            const p = event.extendedProps;
            document.getElementById('detCitaId').value = p.citaId;
            document.getElementById('detCliente').textContent = event.title.split(' · ')[0] || '-';
            document.getElementById('detEmpleado').textContent = p.empleado || '-';
            document.getElementById('detServicio').textContent = p.servicio || '-';
            document.getElementById('detEstado').textContent = p.estado || '-';
            document.getElementById('detNotas').textContent = p.notas || 'Sin notas';
            document.getElementById('detInicio').textContent = event.start ? event.start.toLocaleString('es-ES') : '-';
            document.getElementById('detFin').textContent = event.end ? event.end.toLocaleString('es-ES') : '-';
            document.getElementById('nuevoEstado').value = p.estadoId ?? 1;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalCita')).show();
        }

        function abrirModalHorario(startStr, endStr) {
            document.getElementById('horApertura').value = startStr ? startStr.substring(0, 16) : '';
            document.getElementById('horCierre').value = endStr ? endStr.substring(0, 16) : '';
            document.getElementById('horError').classList.add('d-none');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalHorario')).show();
        }

        async function guardarEstado() {
            const citaId = parseInt(document.getElementById('detCitaId').value);
            const estadoId = parseInt(document.getElementById('nuevoEstado').value);
            const resp = await fetch('/Calendario/CambiarEstado', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ citaId, estadoId })
            });
            if (resp.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modalCita')).hide();
                calendar.refetchEvents();
            }
        }

        async function guardarHorario() {
            const empleadoId = parseInt(document.getElementById('horEmpleado').value);
            const apertura = document.getElementById('horApertura').value;
            const cierre = document.getElementById('horCierre').value;
            const errEl = document.getElementById('horError');
            errEl.classList.add('d-none');
            if (!apertura || !cierre) {
                errEl.textContent = 'Completa los campos de apertura y cierre.';
                errEl.classList.remove('d-none');
                return;
            }
            if (new Date(apertura) >= new Date(cierre)) {
                errEl.textContent = 'La apertura debe ser anterior al cierre.';
                errEl.classList.remove('d-none');
                return;
            }
            if (new Date(apertura) < new Date()) {
                errEl.textContent = 'No se pueden añadir horarios en fechas pasadas.';
                errEl.classList.remove('d-none');
                return;
            }
            const resp = await fetch('/Calendario/AgregarHorario', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ empleadoId, apertura, cierre })
            });
            if (resp.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modalHorario')).hide();
                calendar.refetchEvents();
            } else {
                errEl.textContent = 'Error al guardar el horario. Inténtalo de nuevo.';
                errEl.classList.remove('d-none');
            }
        }

        function abrirModalServicio() {
            document.getElementById('srvNombre').value = '';
            document.getElementById('srvPrecio').value = '';
            document.getElementById('srvDuracion').value = '';
            document.getElementById('srvError').classList.add('d-none');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalServicio')).show();
        }

        async function guardarServicio() {
            const nombre = document.getElementById('srvNombre').value.trim();
            const precio = parseFloat(document.getElementById('srvPrecio').value);
            const duracionMin = parseInt(document.getElementById('srvDuracion').value);
            const errEl = document.getElementById('srvError');
            errEl.classList.add('d-none');
            if (!nombre || isNaN(precio) || precio <= 0 || isNaN(duracionMin) || duracionMin <= 0) {
                errEl.textContent = 'Completa todos los campos correctamente.';
                errEl.classList.remove('d-none');
                return;
            }
            const resp = await fetch('/Calendario/AgregarServicio', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, precio, duracionMin, peluqueriaId })
            });
            if (resp.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modalServicio')).hide();
                location.reload();
            } else {
                errEl.textContent = 'Error al guardar el servicio. Comprueba que no existe ya.';
                errEl.classList.remove('d-none');
            }
        }

        function abrirModalEmpleado() {
            document.getElementById('empNombre').value = '';
            document.getElementById('empError').classList.add('d-none');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalEmpleado')).show();
        }

        async function guardarEmpleado() {
            const nombre = document.getElementById('empNombre').value.trim();
            const errEl = document.getElementById('empError');
            errEl.classList.add('d-none');
            if (!nombre) {
                errEl.textContent = 'El nombre es obligatorio.';
                errEl.classList.remove('d-none');
                return;
            }
            const resp = await fetch('/Calendario/AgregarEmpleado', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, peluqueriaId })
            });
            if (resp.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modalEmpleado')).hide();
                location.reload();
            } else {
                errEl.textContent = 'Error al guardar el empleado. Comprueba que no existe ya.';
                errEl.classList.remove('d-none');
            }
        }

        async function confirmarEliminarHorario(event) {
            const p = event.extendedProps;
            const result = await Swal.fire({
                title: '¿Eliminar horario?',
                html: `Horario de <strong>${p.empleadoNombre}</strong><br>
                       <span class="text-muted small">${event.start?.toLocaleString('es-ES') ?? ''} – ${event.end?.toLocaleString('es-ES') ?? ''}</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="fas fa-trash me-1"></i> Eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            });
            if (!result.isConfirmed) return;
            const resp = await fetch('/Calendario/EliminarHorario', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: p.horarioId })
            });
            if (resp.ok) {
                calendar.refetchEvents();
            } else {
                Swal.fire({ icon: 'error', title: 'Error al eliminar el horario', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
            }
        }

